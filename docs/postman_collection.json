{
  "info": {
    "name": "GigFlow / Smart Leads Dashboard API",
    "description": "Postman collection for the Smart Leads Dashboard project. Includes health, authentication, current-user, and leads management endpoints with JWT bearer auth support.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api/v1"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "leadId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Checks whether the backend API is running."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200 or 201', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Registration succeeded', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "  pm.expect(json.data.token).to.be.a('string');",
                  "});",
                  "",
                  "if (json?.data?.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Yogarathinam\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"Password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Registers a new user and stores the returned JWT token in the collection variable."
          },
          "response": []
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Login succeeded', function () {",
                  "  pm.expect(json.success).to.eql(true);",
                  "  pm.expect(json.data.token).to.be.a('string');",
                  "});",
                  "",
                  "if (json?.data?.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Logs in an existing user and updates the collection token variable."
          },
          "response": []
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            },
            "description": "Fetches the authenticated user's profile using the stored JWT token."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Leads",
      "item": [
        {
          "name": "Create Lead",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "pm.test('Lead created successfully', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "  pm.expect(json.success).to.eql(true);",
                  "});",
                  "",
                  "const leadId = json?.data?.id || json?.data?._id || json?.data?.lead?.id || json?.data?.lead?._id;",
                  "",
                  "if (leadId) {",
                  "  pm.collectionVariables.set('leadId', leadId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Rahul Sharma\",\n  \"email\": \"rahul.sharma@example.com\",\n  \"status\": \"new\",\n  \"source\": \"website\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/leads",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "leads"
              ]
            },
            "description": "Creates a new lead and stores the created lead id in the collection variable if present in the response."
          },
          "response": []
        },
        {
          "name": "Get Leads - Page 1",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/leads?page=1&sort=latest",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "leads"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "sort",
                  "value": "latest"
                }
              ]
            },
            "description": "Fetches paginated leads list with latest-first sorting."
          },
          "response": []
        },
        {
          "name": "Get Leads - Filtered",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/leads?page=1&status=qualified&source=instagram&search=rahul&sort=latest",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "leads"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "status",
                  "value": "qualified"
                },
                {
                  "key": "source",
                  "value": "instagram"
                },
                {
                  "key": "search",
                  "value": "rahul"
                },
                {
                  "key": "sort",
                  "value": "latest"
                }
              ]
            },
            "description": "Fetches leads with combined status, source, search, and sort filters."
          },
          "response": []
        },
        {
          "name": "Get Leads - Page 2",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/leads?page=2&sort=latest",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "leads"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "2"
                },
                {
                  "key": "sort",
                  "value": "latest"
                }
              ]
            },
            "description": "Fetches the second page of leads to verify backend pagination."
          },
          "response": []
        },
        {
          "name": "Get Lead By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/leads/{{leadId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "leads",
                "{{leadId}}"
              ]
            },
            "description": "Fetches a single lead using the stored leadId variable."
          },
          "response": []
        },
        {
          "name": "Update Lead",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Rahul Sharma\",\n  \"email\": \"rahul.sharma@example.com\",\n  \"status\": \"qualified\",\n  \"source\": \"instagram\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/leads/{{leadId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "leads",
                "{{leadId}}"
              ]
            },
            "description": "Updates an existing lead using the stored leadId variable."
          },
          "response": []
        },
        {
          "name": "Delete Lead",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/leads/{{leadId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "leads",
                "{{leadId}}"
              ]
            },
            "description": "Deletes a lead using the stored leadId variable."
          },
          "response": []
        },
        {
          "name": "Export Leads CSV",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/leads/export/csv?sort=latest",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "leads",
                "export",
                "csv"
              ],
              "query": [
                {
                  "key": "sort",
                  "value": "latest"
                }
              ]
            },
            "description": "Exports leads as CSV. Add filter query params here if your backend supports filtered export."
          },
          "response": []
        }
      ]
    }
  ]
}